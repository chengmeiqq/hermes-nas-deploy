# === Docker Compose 环境变量 ===
HERMES_IMAGE=ys9898/hermes-agent:latest
HERMES_NAME=hermes
HERMES_DASHBOARD=1

# === Dashboard 认证 ===
DASHBOARD_USER=admin
DASHBOARD_PASS=your_password_here

# === 模型配置 ===
XIAOMI_API_KEY=your_xiaomi_api_key_here
CUSTOM_API_KEY=your_custom_api_key_here

# === 飞书 Bot ===
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
# FEISHU_ALLOWED_USERS=ou_your_open_id_here
# FEISHU_HOME_CHANNEL=oc_your_chat_id_here

# === Gateway ===
# GATEWAY_ALLOW_ALL_USERS=true
